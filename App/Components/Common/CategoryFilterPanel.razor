@namespace App.Components.Translate
@using DeusaldLocalizerCommon
@inject ProjectStateService _ProjectState

<div class="cfp-root">

    @if (!_Expanded)
    {
        <button class="cfp-trigger" @onclick="() => _Expanded = true">
            <i class="bi bi-funnel cfp-trigger-icon"></i>
            <span class="cfp-trigger-label">@TriggerLabel</span>
            <i class="bi bi-chevron-down cfp-trigger-chevron"></i>
        </button>
    }
    else
    {
        <div class="cfp-panel">
            <div class="cfp-panel-header">
                <span class="cfp-panel-title">Filter by category</span>
                <div class="cfp-panel-actions">
                    @if (SelectedCategoryIds.Count > 0)
                    {
                        <button class="cfp-clear-btn" @onclick="ClearAll">Clear</button>
                    }
                    <button class="cfp-collapse-btn" @onclick="() => _Expanded = false">
                        <i class="bi bi-chevron-up"></i>
                    </button>
                </div>
            </div>

            <div class="cfp-list">
                @if (_ProjectState.CurrentProject!.Categories.Count == 0)
                {
                    <div class="cfp-empty">No categories yet.</div>
                }
                else
                {
                    @foreach (var cat in RootCategories)
                    {
                        @RenderCategoryRow(cat, 0)
                    }
                }
            </div>

            @if (IsAdmin)
            {
                <button class="cfp-add-btn" @onclick="() => _NewCategoryModal?.Show()">
                    <i class="bi bi-plus-lg"></i> Add category
                </button>
            }
        </div>
    }

</div>

<NewCategoryModal @ref="_NewCategoryModal" />

@code {
    [Parameter] public HashSet<Guid> SelectedCategoryIds { get; set; } = new();
    [Parameter] public EventCallback<HashSet<Guid>> OnChanged { get; set; }

    private bool _Expanded = false;
    private NewCategoryModal? _NewCategoryModal;

    private bool IsAdmin => _ProjectState.CurrentUserHas(PermissionFlags.Admin);

    private List<CategoryDto> RootCategories =>
        _ProjectState.CurrentProject!.Categories.Where(c => c.ParentCategoryId == null).ToList();

    private List<CategoryDto> ChildrenOf(Guid parentId) =>
        _ProjectState.CurrentProject!.Categories.Where(c => c.ParentCategoryId == parentId).ToList();

    private string TriggerLabel
    {
        get
        {
            if (SelectedCategoryIds.Count == 0) return "All categories";
            if (SelectedCategoryIds.Count == 1)
            {
                var cat = _ProjectState.CurrentProject!.Categories.Find(c => c.Id == SelectedCategoryIds.First());
                return cat?.Name ?? "1 category";
            }
            return $"{SelectedCategoryIds.Count} categories";
        }
    }

    private async Task Toggle(Guid id)
    {
        var next = new HashSet<Guid>(SelectedCategoryIds);
        if (!next.Remove(id)) next.Add(id);
        await OnChanged.InvokeAsync(next);
    }

    private async Task ClearAll()
    {
        await OnChanged.InvokeAsync(new HashSet<Guid>());
    }

    private RenderFragment RenderCategoryRow(CategoryDto cat, int depth) => builder =>
    {
        bool active = SelectedCategoryIds.Contains(cat.Id);
        var children = ChildrenOf(cat.Id);

        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "class", $"cfp-item {(active ? "active" : "")}");
        builder.AddAttribute(2, "style", $"padding-left:{12 + depth * 16}px");
        builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, () => Toggle(cat.Id)));

        builder.OpenElement(4, "span");
        builder.AddAttribute(5, "class", "cfp-item-check");
        if (active) builder.AddContent(6, "✓");
        builder.CloseElement();

        builder.OpenElement(7, "span");
        builder.AddAttribute(8, "class", "cfp-item-name");
        builder.AddContent(9, cat.Name);
        builder.CloseElement();

        builder.CloseElement();

        foreach (var child in children)
        {
            builder.AddContent(10, RenderCategoryRow(child, depth + 1));
        }
    };
}
