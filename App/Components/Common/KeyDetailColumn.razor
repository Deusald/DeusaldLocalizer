@namespace App.Components.Translate
@using DeusaldLocalizerCommon
@inject ProjectStateService _ProjectState

<div class="kd-root">

    @if (SelectedKeyId == null || SelectedKey == null)
    {
        <div class="kd-empty">
            <i class="bi bi-key kd-empty-icon"></i>
            <span>Select a key to start translating</span>
        </div>
    }
    else
    {
        <div class="kd-scroll">

            @* ── Header ───────────────────────────────────────────────────── *@
            <div class="kd-header">
                <div class="kd-header-top">
                    <div class="kd-header-title-row">
                        <span class="kd-key-name">@FullKeyName(SelectedKey)</span>
                        <span class="kd-status-tag @StatusTagClass">@StatusTagLabel</span>
                    </div>
                    <div class="kd-header-dates">
                        <span title="Created">Created @SelectedKey.CreatedAt.ToString("MMM d, yyyy")</span>
                        <span class="kd-dates-sep">·</span>
                        <span title="Last updated">Updated @SelectedKey.UpdatedAt.ToString("MMM d, yyyy")</span>
                    </div>
                </div>

                <KeyFlagsBar Key="@SelectedKey" OnChanged="StateHasChanged" />
            </div>

            @* ── Description ─────────────────────────────────────────────── *@
            <KeyDescriptionBlock Key="@SelectedKey" OnChanged="StateHasChanged" />

            @* ── Tags ─────────────────────────────────────────────────────── *@
            <KeyTagsBar Key="@SelectedKey" OnChanged="StateHasChanged" />

            @* ── Translation editor ──────────────────────────────────────── *@
            <TranslationEditor Key="@SelectedKey" SelectedLanguage="@SelectedLanguage" OnChanged="StateHasChanged" />

            @* ── Preview ──────────────────────────────────────────────────── *@
            <PreviewSection Key="@SelectedKey" SelectedLanguage="@SelectedLanguage" />

            @* ── Suggestions ──────────────────────────────────────────────── *@
            <SuggestionsSection Key="@SelectedKey" SelectedLanguage="@SelectedLanguage" OnChanged="StateHasChanged" />

            @* ── Variables ────────────────────────────────────────────────── *@
            <VariablesSection Key="@SelectedKey" OnChanged="StateHasChanged" />

            @* ── History ──────────────────────────────────────────────────── *@
            <div class="kd-history-row">
                <button class="kd-history-btn" @onclick="() => _HistoryModal?.Show()">
                    <i class="bi bi-clock-history"></i> View history
                    <span class="kd-history-count">@SelectedKey.History.Count</span>
                </button>
            </div>

        </div>

        <HistoryModal @ref="_HistoryModal" Key="@SelectedKey" />
    }

</div>

@code {
    [Parameter] public string SelectedLanguage { get; set; } = "";
    [Parameter] public Guid? SelectedKeyId { get; set; }

    private HistoryModal? _HistoryModal;

    private LocalizationKeyDto? SelectedKey =>
        SelectedKeyId == null ? null : _ProjectState.CurrentProject!.Keys.Find(k => k.Id == SelectedKeyId);

    private string FullKeyName(LocalizationKeyDto key)
    {
        var project = _ProjectState.CurrentProject!;
        var cat = project.Categories.Find(c => c.Id == key.CategoryId);
        if (cat == null) return key.KeyName;

        var parts = new List<string> { cat.Name };
        var current = cat;
        while (current.ParentCategoryId != null)
        {
            var parent = project.Categories.Find(c => c.Id == current.ParentCategoryId);
            if (parent == null) break;
            parts.Insert(0, parent.Name);
            current = parent;
        }
        return $"{string.Join("/", parts)}.{key.KeyName}";
    }

    private string StatusTagLabel
    {
        get
        {
            var key = SelectedKey!;
            if (key.Flags.Any(f => f.Type == FlagType.NeedsReview)) return "Needs review";
            var t = key.Translations.Find(tr => tr.LanguageId == SelectedLanguage);
            if (t == null || string.IsNullOrEmpty(t.Text)) return "Untranslated";
            if (t.NeedsAttention) return "Needs review";
            return t.Status switch
            {
                TranslationStatus.Approved  => "Approved",
                TranslationStatus.Suggested => "Suggested",
                _ => "Draft",
            };
        }
    }

    private string StatusTagClass => StatusTagLabel switch
    {
        "Approved"      => "kd-status-ok",
        "Needs review"  => "kd-status-warn",
        "Untranslated"  => "kd-status-empty",
        _               => "kd-status-draft",
    };
}
