@namespace App.Components.Translate
@using DeusaldLocalizerCommon
@inject ProjectStateService _ProjectState

<div class="ktb-root">
    @if (Key.Tags.Count == 0 && !IsAdmin)
    {
        <span class="ktb-empty">No tags</span>
    }
    else
    {
        @foreach (var tag in Key.Tags)
        {
            var t = tag;
            <span class="ktb-tag" @onmouseenter="() => _Hovered = t" @onmouseleave="() => _Hovered = null">
                #@t
                @if (IsAdmin && _Hovered == t)
                {
                    <button class="ktb-tag-remove" @onclick="() => RemoveTag(t)">
                        <i class="bi bi-x"></i>
                    </button>
                }
            </span>
        }

        @if (IsAdmin)
        {
            <button class="ktb-add-btn" @onclick="() => _AddTagModal?.Show()">
                <i class="bi bi-plus"></i>
            </button>
        }
    }
</div>

<AddTagModal @ref="_AddTagModal" Key="Key" OnAdded="OnAdded" />

@code {
    [Parameter] public LocalizationKeyDto Key       { get; set; } = null!;
    [Parameter] public EventCallback      OnChanged { get; set; }

    private string?      _Hovered;
    private AddTagModal? _AddTagModal;

    private bool IsAdmin => _ProjectState.CurrentUserHas(PermissionFlags.Admin);

    private async Task OnAdded() => await OnChanged.InvokeAsync();

    private void RemoveTag(string tag)
    {
        Key.Tags.Remove(tag);
        _ProjectState.MarkDirty();
        _Hovered = null;
        OnChanged.InvokeAsync();
    }
}