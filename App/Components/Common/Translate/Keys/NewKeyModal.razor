@namespace App.Components.Translate
@using System.Text.RegularExpressions
@using DeusaldLocalizerCommon
@inject ProjectStateService _ProjectState

@if (_Visible)
{
    <div class="nkm-backdrop" @onclick="Cancel"></div>

    <div class="nkm-box" @onclick:stopPropagation="true">

        <div class="nkm-header">
            <span class="nkm-title">New key</span>
            <button class="nkm-close" @onclick="Cancel"><i class="bi bi-x-lg"></i></button>
        </div>

        <div class="nkm-body">

            <div class="nkm-field">
                <label class="nkm-label">
                    Key name
                    <span class="nkm-label-hint">letters, numbers and underscore only</span>
                </label>
                <input class="nkm-input nkm-input-mono" type="text" placeholder="button_save"
                       @bind="_KeyName" @bind:event="oninput" maxlength="120" />
                @if (!string.IsNullOrEmpty(_KeyName) && !IsValidKeyName(_KeyName))
                {
                    <div class="nkm-field-error">Only letters, numbers and "_" are allowed</div>
                }
            </div>

            <div class="nkm-field nkm-field-grow">
                <label class="nkm-label">Category</label>
                <div class="nkm-cat-picker">
                    <div class="nkm-cat-search-wrap">
                        @if (_SelectedCategory != null && !_CatOpen)
                        {
                            <span class="nkm-cat-selected-icon">
                                <i class="bi bi-folder2"></i>
                            </span>
                            <button class="nkm-cat-selected-display" @onclick="() => _CatOpen = true">
                                @FullCategoryPath(_SelectedCategory)
                            </button>
                            <button class="nkm-cat-clear" @onclick="ClearCategory" @onclick:stopPropagation="true">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                        else
                        {
                            <i class="bi bi-search nkm-cat-search-icon"></i>
                            <input class="nkm-input nkm-cat-search" type="text"
                                   placeholder="Search category…"
                                   @bind="_CatQuery" @bind:event="oninput"
                                   @onfocus="() => _CatOpen = true"
                                   @onblur="OnCatBlur" />
                        }
                    </div>

                    @if (_CatOpen)
                    {
                        <div class="nkm-cat-dropdown" @onmousedown="() => _SuppressBlurClose = true">
                            @{ List<CategoryDto> results = _FilteredCategories; }
                            @if (results.Count == 0)
                            {
                                <div class="nkm-cat-empty">No categories found. Create one from the Keys column first.</div>
                            }
                            else
                            {
                                @foreach (CategoryDto cat in results)
                                {
                                    CategoryDto c = cat;
                                    bool active = _SelectedCategory?.Id == c.Id;
                                    <button class="nkm-cat-item @(active ? "active" : "")"
                                            @onclick="() => SelectCategory(c)"
                                            @onclick:preventDefault="true">
                                        <span class="nkm-cat-item-name">@FullCategoryPath(c)</span>
                                        @if (active)
                                        {
                                            <i class="bi bi-check2"></i>
                                        }
                                    </button>
                                }
                            }
                        </div>
                    }
                </div>
            </div>

            @if (!_CatOpen)
            {
                <div class="nkm-preview">
                    <span class="nkm-preview-label">Full key</span>
                    <code class="nkm-preview-value">@_PreviewFullKey</code>
                </div>
            }

        </div>

        <div class="nkm-footer">
            <button class="nkm-btn nkm-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="nkm-btn nkm-btn-primary" @onclick="Confirm" disabled="@(!_CanConfirm)">
                Create key
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<Guid> OnCreated { get; set; }

    private bool         _Visible;
    private string       _KeyName  = "";
    private string       _CatQuery = "";
    private bool         _CatOpen;
    private bool         _SuppressBlurClose;
    private CategoryDto? _SelectedCategory;

    private static readonly Regex _KeyNamePattern = new(@"^[A-Za-z0-9_]+$");

    private static bool IsValidKeyName(string s) => !string.IsNullOrEmpty(s) && _KeyNamePattern.IsMatch(s);

    private bool _CanConfirm => IsValidKeyName(_KeyName) && _SelectedCategory != null;

    private List<CategoryDto> _FilteredCategories
    {
        get
        {
            IEnumerable<CategoryDto> cats = _ProjectState.CurrentProject!.Categories.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_CatQuery))
            {
                string q = _CatQuery.Trim().ToLowerInvariant();
                cats = cats.Where(c => FullCategoryPath(c).ToLowerInvariant().Contains(q));
            }
            return cats.ToList();
        }
    }

    private string FullCategoryPath(CategoryDto cat)
    {
        List<string> parts   = [cat.Name];
        CategoryDto  current = cat;
        ProjectDto   project = _ProjectState.CurrentProject!;
        while (current.ParentCategoryId != null)
        {
            CategoryDto? parent = project.Categories.Find(c => c.Id == current.ParentCategoryId);
            if (parent == null) break;
            parts.Insert(0, parent.Name);
            current = parent;
        }
        return string.Join("/", parts);
    }

    private string _PreviewFullKey =>
        _SelectedCategory != null && !string.IsNullOrEmpty(_KeyName)
            ? $"{FullCategoryPath(_SelectedCategory)}.{_KeyName}"
            : "—";

    public void Show()
    {
        _KeyName = "";
        _CatQuery = "";
        _CatOpen = false;
        _SuppressBlurClose = false;
        _SelectedCategory = null;
        _Visible = true;
        StateHasChanged();
    }

    private void SelectCategory(CategoryDto cat)
    {
        _SelectedCategory = cat;
        _CatQuery = "";
        _CatOpen = false;
    }

    private async Task OnCatBlur()
    {
        // A mousedown on a dropdown item fires before this blur event, so we
        // use it as a guard to avoid closing the list before the click
        // (which selects a result) has a chance to register.
        if (_SuppressBlurClose)
        {
            _SuppressBlurClose = false;
            return;
        }
        await Task.Delay(120);
        _CatOpen = false;
        StateHasChanged();
    }

    private void ClearCategory()
    {
        _SelectedCategory = null;
    }

    private void Confirm()
    {
        if (!_CanConfirm) return;

        ProjectDto project = _ProjectState.CurrentProject!;
        LocalizationKeyDto key = new LocalizationKeyDto
        {
            ProjectId  = project.Id,
            CategoryId = _SelectedCategory!.Id,
            KeyName    = _KeyName.Trim(),
        };
        project.Keys.Add(key);
        _ProjectState.MarkDirty();

        _Visible = false;
        OnCreated.InvokeAsync(key.Id);
    }

    private void Cancel() => _Visible = false;
}
