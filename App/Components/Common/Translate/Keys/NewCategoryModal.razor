@namespace App.Components.Translate
@using DeusaldLocalizerCommon
@using Newtonsoft.Json
@inject ProjectStateService _ProjectState

@if (_Visible)
{
    <div class="ncm-backdrop" @onclick="Cancel"></div>

    <div class="ncm-box" @onclick:stopPropagation="true">

        <div class="ncm-header">
            <span class="ncm-title">@(_EditingCategory == null ? "New category" : "Edit category")</span>
            <button class="ncm-close" @onclick="Cancel"><i class="bi bi-x-lg"></i></button>
        </div>

        <div class="ncm-body">

            <div class="ncm-field">
                <label class="ncm-label">Category name</label>
                <input class="ncm-input" type="text" placeholder="Menu"
                       @bind="_Name" @bind:event="oninput" maxlength="80" />
            </div>

            <div class="ncm-field">
                <label class="ncm-label">Parent category <span class="ncm-label-hint">optional</span></label>
                <div class="ncm-parent-picker">
                    <div class="ncm-parent-search-wrap">
                        @if (_SelectedParent != null && !_ParentOpen)
                        {
                            <span class="ncm-parent-selected-icon">
                                <i class="bi bi-folder2"></i>
                            </span>
                            <button class="ncm-parent-selected-display" @onclick="() => _ParentOpen = true">
                                @FullPath(_SelectedParent)
                            </button>
                            <button class="ncm-parent-clear" @onclick="ClearParent" @onclick:stopPropagation="true">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                        else
                        {
                            <i class="bi bi-search ncm-parent-search-icon"></i>
                            <input class="ncm-input ncm-parent-search" type="text"
                                   placeholder="Search category…"
                                   @bind="_ParentQuery" @bind:event="oninput"
                                   @onfocus="() => _ParentOpen = true"
                                   @onblur="OnParentBlur" />
                        }
                    </div>

                    @if (_ParentOpen)
                    {
                        <div class="ncm-parent-dropdown" @onmousedown="() => _SuppressBlurClose = true">
                            <button class="ncm-parent-item @(_SelectedParent == null ? "active" : "")"
                                    @onclick="() => SelectParent(null)"
                                    @onclick:preventDefault="true">
                                <span class="ncm-parent-item-name ncm-parent-item-none">None</span>
                                @if (_SelectedParent == null)
                                {
                                    <i class="bi bi-check2"></i>
                                }
                            </button>
                            <div class="ncm-parent-divider"></div>

                            @{ List<CategoryDto> results = _FilteredParents; }
                            @if (results.Count == 0)
                            {
                                <div class="ncm-parent-empty">No categories found</div>
                            }
                            else
                            {
                                @foreach (CategoryDto cat in results)
                                {
                                    CategoryDto c = cat;
                                    bool active = _SelectedParent?.Id == c.Id;
                                    string path = FullPath(c);
                                    <button class="ncm-parent-item @(active ? "active" : "")"
                                            @onclick="() => SelectParent(c)"
                                            @onclick:preventDefault="true">
                                        <span class="ncm-parent-item-name">@path</span>
                                        @if (active)
                                        {
                                            <i class="bi bi-check2"></i>
                                        }
                                    </button>
                                }
                            }
                        </div>
                    }
                </div>
            </div>

            @if (!_ParentOpen)
            {
                <div class="ncm-field">
                    <label class="ncm-label">
                        Description <span class="ncm-label-hint">optional</span>
                    </label>
                    <textarea class="ncm-input ncm-textarea" placeholder="What kind of keys live here…"
                              @bind="_Description" @bind:event="oninput" rows="3" maxlength="300"></textarea>
                </div>
            }

        </div>

        <div class="ncm-footer">
            <button class="ncm-btn ncm-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="ncm-btn ncm-btn-primary" @onclick="Confirm" disabled="@(string.IsNullOrWhiteSpace(_Name))">
                @(_EditingCategory == null ? "Create category" : "Save changes")
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback OnCreated { get; set; }

    private bool         _Visible;
    private string       _Name        = "";
    private string       _Description = "";
    private string       _ParentQuery = "";
    private bool         _ParentOpen;
    private bool         _SuppressBlurClose;
    private CategoryDto? _SelectedParent;
    private CategoryDto? _EditingCategory;

    private List<CategoryDto> _FilteredParents
    {
        get
        {
            HashSet<Guid> excluded = _EditingCategory == null
                                         ? new HashSet<Guid>()
                                         : DescendantsAndSelf(_EditingCategory);

            IEnumerable<CategoryDto> cats = _ProjectState.CurrentProject!.Categories
                                                         .Where(c => !excluded.Contains(c.Id))
                                                         .AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_ParentQuery))
            {
                string q = _ParentQuery.Trim().ToLowerInvariant();
                cats = cats.Where(c => FullPath(c).ToLowerInvariant().Contains(q));
            }
            return cats.OrderBy(FullPath, StringComparer.OrdinalIgnoreCase).ToList();
        }
    }

    /// <summary>A category's own id plus every descendant id — used to prevent picking a cyclical parent while editing.</summary>
    private HashSet<Guid> DescendantsAndSelf(CategoryDto cat)
    {
        ProjectDto    project = _ProjectState.CurrentProject!;
        HashSet<Guid> result  = new HashSet<Guid> { cat.Id };

        void Walk(Guid parentId)
        {
            foreach (CategoryDto child in project.Categories.Where(c => c.ParentCategoryId == parentId))
            {
                if (result.Add(child.Id)) Walk(child.Id);
            }
        }

        Walk(cat.Id);
        return result;
    }

    /// <summary>Builds the full "parent/child" path for a category, e.g. "menu/buttons".</summary>
    private string FullPath(CategoryDto cat)
    {
        ProjectDto   project = _ProjectState.CurrentProject!;
        List<string> parts   = new List<string> { cat.Name };
        CategoryDto          current = cat;
        while (current.ParentCategoryId != null)
        {
            CategoryDto? parent = project.Categories.Find(c => c.Id == current.ParentCategoryId);
            if (parent == null) break;
            parts.Insert(0, parent.Name);
            current = parent;
        }
        return string.Join("/", parts);
    }

    public void Show()
    {
        _Name = "";
        _Description = "";
        _ParentQuery = "";
        _ParentOpen = false;
        _SuppressBlurClose = false;
        _SelectedParent = null;
        _EditingCategory = null;
        _Visible = true;
        StateHasChanged();
    }

    public void EditCategory(CategoryDto category)
    {
        _EditingCategory = category;
        _Name = category.Name;
        _Description = category.Description;
        _ParentQuery = "";
        _ParentOpen = false;
        _SuppressBlurClose = false;
        _SelectedParent = category.ParentCategoryId == null
            ? null
            : _ProjectState.CurrentProject!.Categories.Find(c => c.Id == category.ParentCategoryId);
        _Visible = true;
        StateHasChanged();
    }

    private void SelectParent(CategoryDto? cat)
    {
        _SelectedParent = cat;
        _ParentQuery = "";
        _ParentOpen = false;
    }

    private async Task OnParentBlur()
    {
        // A mousedown on a dropdown item fires before this blur event, so we
        // use it as a guard to avoid closing the list before the click
        // (which selects a result) has a chance to register.
        if (_SuppressBlurClose)
        {
            _SuppressBlurClose = false;
            return;
        }
        await Task.Delay(120);
        _ParentOpen = false;
        StateHasChanged();
    }

    private void ClearParent()
    {
        _SelectedParent = null;
    }

    private void Confirm()
    {
        if (string.IsNullOrWhiteSpace(_Name)) return;

        ProjectDto project = _ProjectState.CurrentProject!;

        if (_EditingCategory == null)
        {
            CategoryDto newCategory = new CategoryDto
            {
                ProjectId        = project.Id,
                Name             = _Name.Trim(),
                Description      = _Description.Trim(),
                ParentCategoryId = _SelectedParent?.Id,
            };
            
            project.Categories.Add(newCategory);
            
            project.ProjectHistory.Add(new HistoryEntryDto
            {
                EntityPartName = "Categories",
                EntityPartId   = newCategory.Id,
                ChangeType     = HistoryChangeType.Created,
                OldValue       = string.Empty,
                NewValue       = JsonConvert.SerializeObject(newCategory),
                UserId         = _ProjectState.CurrentUser.Id,
                UserName       = _ProjectState.CurrentUser.DisplayName
            });
        }
        else
        {
            string oldCategory = JsonConvert.SerializeObject(_EditingCategory);
            
            _EditingCategory.Name             = _Name.Trim();
            _EditingCategory.Description      = _Description.Trim();
            _EditingCategory.ParentCategoryId = _SelectedParent?.Id;
            
            project.ProjectHistory.Add(new HistoryEntryDto
            {
                EntityPartName = "Categories",
                EntityPartId   = _EditingCategory.Id,
                ChangeType     = HistoryChangeType.Updated,
                OldValue       = oldCategory,
                NewValue       = JsonConvert.SerializeObject(_EditingCategory),
                UserId         = _ProjectState.CurrentUser.Id,
                UserName       = _ProjectState.CurrentUser.DisplayName
            });
        }

        _ProjectState.MarkDirty();

        _Visible = false;
        OnCreated.InvokeAsync();
    }

    private void Cancel() => _Visible = false;
}
