@namespace App.Components.Translate
@using DeusaldLocalizerCommon
@inject ProjectStateService _ProjectState

<div class="kdb-root">
    @if (_Editing)
    {
        <textarea class="kdb-textarea" @bind="_Draft" @bind:event="oninput"
                  @onblur="Save" rows="2" placeholder="Add a description for translators…"></textarea>
    }
    else if (_IsAdmin)
    {
        <button class="kdb-display kdb-editable" @onclick="StartEdit">
            @(string.IsNullOrWhiteSpace(Key.Description) ? "Add a description…" : Key.Description)
        </button>
    }
    else
    {
        <div class="kdb-display">
            @(string.IsNullOrWhiteSpace(Key.Description) ? "No description." : Key.Description)
        </div>
    }
</div>

@code {
    [Parameter] public LocalizationKeyDto Key       { get; set; } = null!;
    [Parameter] public EventCallback      OnChanged { get; set; }

    private bool   _Editing;
    private string _Draft = "";

    private bool _IsAdmin => _ProjectState.CurrentUserHas(PermissionFlags.Admin);

    private void StartEdit()
    {
        _Draft   = Key.Description;
        _Editing = true;
    }

    private async Task Save()
    {
        string oldDescription = Key.Description;
        _Editing = false;

        if (Key.Description == _Draft.Trim()) return;

        Key.Description = _Draft.Trim();
        Key.UpdatedAt   = DateTime.UtcNow;

        Key.History.Add(new HistoryEntryDto
        {
            EntityPartName = "Description",
            EntityPartId   = Key.Id,
            ChangeType     = HistoryChangeType.Updated,
            OldValue       = oldDescription,
            NewValue       = Key.Description,
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });

        _ProjectState.MarkDirty();

        await OnChanged.InvokeAsync();
    }

}