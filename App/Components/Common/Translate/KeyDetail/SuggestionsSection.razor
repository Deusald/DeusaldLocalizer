@namespace App.Components.Translate
@using DeusaldLocalizerCommon
@using Newtonsoft.Json
@inject ProjectStateService _ProjectState

@{ List<SuggestionDto> suggestions = _SuggestionsForLanguage; }

@if (suggestions.Count > 0)
{
    <div class="ss-root">
        <div class="ss-label">Community suggestions</div>

        <div class="ss-list">
            @foreach (SuggestionDto suggestion in suggestions)
            {
                SuggestionDto s = suggestion;
                int score = s.Votes.Sum(v => v.Value);
                int myVote = s.Votes.Find(v => v.UserId == _ProjectState.CurrentUser.Id)?.Value ?? 0;
                string preview = VariablePreviewService.Render(s.Text, Key.Variables, PreviewOverrides, _ProjectState.CurrentProject!.Enums);

                <div class="ss-item">
                    <div class="ss-vote">
                        <button class="ss-vote-btn @(myVote == 1 ? "active" : "")" @onclick="() => Vote(s, 1)">
                            <i class="bi bi-caret-up-fill"></i>
                        </button>
                        <span class="ss-vote-score">@score</span>
                        <button class="ss-vote-btn @(myVote == -1 ? "active" : "")" @onclick="() => Vote(s, -1)">
                            <i class="bi bi-caret-down-fill"></i>
                        </button>
                    </div>

                    <div class="ss-content">
                        <div class="ss-text">@s.Text</div>
                        @if (preview != s.Text)
                        {
                            <div class="ss-preview">@preview</div>
                        }
                        <div class="ss-meta">
                            <span class="ss-avatar" style="background:@AvatarColor(s.AuthorId)">@Initial(s.AuthorName)</span>
                            <span class="ss-author">@s.AuthorName</span>
                            <span class="ss-dot">·</span>
                            <span class="ss-time">@RelativeTime(s.CreatedAt)</span>
                        </div>
                    </div>

                    @if (_CanAccept)
                    {
                        <div class="ss-review-actions">
                            <button class="ss-accept-btn" @onclick="() => Accept(s)">Accept</button>
                            <button class="ss-reject-btn" @onclick="() => Reject(s)">Reject</button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public LocalizationKeyDto       Key              { get; set; } = null!;
    [Parameter] public string                   SelectedLanguage { get; set; } = "";
    [Parameter] public EventCallback            OnChanged        { get; set; }
    [Parameter] public Dictionary<Guid, string> PreviewOverrides { get; set; } = new();

    private bool _CanAccept => _ProjectState.CurrentUserHas(PermissionFlags.Reviewer)
                            || _ProjectState.CurrentUserHas(PermissionFlags.Admin);

    private List<SuggestionDto> _SuggestionsForLanguage =>
        Key.Translations.FirstOrDefault(t => t.LanguageId == SelectedLanguage)?.Suggestions
           .Where(s => s.Status == SuggestionStatus.Pending)
           .OrderByDescending(s => s.Votes.Sum(v => v.Value))
           .ToList() ?? [];

    private void Vote(SuggestionDto suggestion, int value)
    {
        string oldJson = JsonConvert.SerializeObject(suggestion);
        SuggestionVoteDto? existing = suggestion.Votes.Find(v => v.UserId == _ProjectState.CurrentUser.Id);
        if (existing != null)
        {
            if (existing.Value == value)
            {
                suggestion.Votes.Remove(existing); // toggle off
            }
            else
            {
                existing.Value = value;
                existing.CastAt = DateTime.UtcNow;
            }
        }
        else
        {
            suggestion.Votes.Add(new SuggestionVoteDto
            {
                SuggestionId = suggestion.Id,
                UserId       = _ProjectState.CurrentUser.Id,
                UserName     = _ProjectState.CurrentUser.DisplayName,
                Value        = value,
            });
        }
        
        Key.History.Add(new HistoryEntryDto
        {
            EntityPartName = $"Translation-Suggestion-Vote/{SelectedLanguage}",
            EntityPartId   = suggestion.Id,
            ChangeType     = HistoryChangeType.Updated,
            OldValue       = oldJson,
            NewValue       = JsonConvert.SerializeObject(suggestion),
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });
        
        _ProjectState.MarkDirty();
        OnChanged.InvokeAsync();
    }

    private void Accept(SuggestionDto suggestion)
    {
        TranslationDto translation = Key.Translations.Find(t => t.Id == suggestion.TranslationId)!;
        string         oldText     = translation.Text;
        translation.Text           = suggestion.Text;
        translation.Status         = TranslationStatus.Approved;
        translation.NeedsAttention = false;
        translation.UpdatedBy      = _ProjectState.CurrentUser.Id;
        translation.UpdatedAt      = DateTime.UtcNow;

        suggestion.Status = SuggestionStatus.Accepted;
        Key.UpdatedAt = DateTime.UtcNow;

        Key.History.Add(new HistoryEntryDto
        {
            EntityPartName = $"Translation-Suggestion/{SelectedLanguage}",
            EntityPartId   = suggestion.Id,
            ChangeType     = HistoryChangeType.Approved,
            OldValue       = oldText,
            NewValue       = suggestion.Text,
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });

        translation.Suggestions.Remove(suggestion);
        
        _ProjectState.MarkDirty();
        OnChanged.InvokeAsync();
    }

    private void Reject(SuggestionDto suggestion)
    {
        suggestion.Status = SuggestionStatus.Rejected;
        Key.UpdatedAt = DateTime.UtcNow;

        TranslationDto translation = Key.Translations.First(t => t.LanguageId == SelectedLanguage);
        
        if (_SuggestionsForLanguage.Count(s => s.Status == SuggestionStatus.Pending) == 0
         && translation.Status == TranslationStatus.Approved)
        {
            translation.NeedsAttention = false;
        }
        
        Key.History.Add(new HistoryEntryDto
        {
            EntityPartName = $"Translation-Suggestion/{SelectedLanguage}",
            EntityPartId   = suggestion.Id,
            ChangeType     = HistoryChangeType.Rejected,
            OldValue       = string.Empty,
            NewValue       = suggestion.Text,
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });

        translation.Suggestions.Remove(suggestion);
        
        _ProjectState.MarkDirty();
        OnChanged.InvokeAsync();
    }

    private static string Initial(string name) => string.IsNullOrEmpty(name) ? "?" : name.Substring(0, 1).ToUpper();

    private static readonly string[] _AvatarPalette = ["#5b6cff", "#3ad98a", "#ff6b6b", "#f5a623", "#a78bfa", "#36c5f0"];

    private static string AvatarColor(Guid userId)
    {
        int idx = Math.Abs(userId.GetHashCode()) % _AvatarPalette.Length;
        return _AvatarPalette[idx];
    }

    private static string RelativeTime(DateTime time)
    {
        TimeSpan diff = DateTime.UtcNow - time;
        if (diff.TotalMinutes < 1)  return "just now";
        if (diff.TotalHours   < 1)  return $"{(int)diff.TotalMinutes}m";
        if (diff.TotalDays    < 1)  return $"{(int)diff.TotalHours}h";
        if (diff.TotalDays    < 30) return $"{(int)diff.TotalDays}d";
        return time.ToString("MMM d");
    }
}
