@namespace App.Components.Translate
@using DeusaldLocalizerCommon
@using Newtonsoft.Json
@inject ProjectStateService _ProjectState

@if (_Visible)
{
    <div class="pem-backdrop" @onclick="Close"></div>

    <div class="pem-box" @onclick:stopPropagation="true">

        <div class="pem-header">
            <span class="pem-title">Project enums</span>
            <button class="pem-close" @onclick="Close"><i class="bi bi-x-lg"></i></button>
        </div>

        <div class="pem-body">

            @* ── Enum list ──────────────────────────────────────────────── *@
            <div class="pem-list-col">
                <div class="pem-col-header">
                    <span class="pem-col-label">Enums</span>
                    <button class="pem-add-btn" @onclick="AddEnum">
                        <i class="bi bi-plus"></i>
                    </button>
                </div>

                <div class="pem-enum-list">
                    @foreach (var e in _ProjectState.CurrentProject!.Enums)
                    {
                        var locEnum = e;
                        bool active = _SelectedEnum?.Id == locEnum.Id;
                        <button class="pem-enum-item @(active ? "active" : "")"
                                @onclick="() => SelectEnum(locEnum)">
                            <span class="pem-enum-item-name">@(string.IsNullOrEmpty(locEnum.Name) ? "Unnamed" : locEnum.Name)</span>
                            <span class="pem-enum-item-count">@locEnum.Entries.Count</span>
                        </button>
                    }

                    @if (_ProjectState.CurrentProject.Enums.Count == 0)
                    {
                        <div class="pem-empty">No enums yet.</div>
                    }
                </div>
            </div>

            @* ── Enum editor ────────────────────────────────────────────── *@
            <div class="pem-editor-col">
                @if (_SelectedEnum == null)
                {
                    <div class="pem-editor-empty">Select an enum to edit it.</div>
                }
                else
                {
                    <div class="pem-editor-fields">
                        <div class="pem-field">
                            <label class="pem-label">Name</label>
                            <input class="pem-input" type="text" placeholder="Gender"
                                   @bind="_SelectedEnum.Name" @bind:event="oninput"
                                   @bind:after="MarkDirty" />
                        </div>
                        <div class="pem-field">
                            <label class="pem-label">Description <span class="pem-label-hint">optional</span></label>
                            <input class="pem-input" type="text" placeholder="Grammatical gender"
                                   @bind="_SelectedEnum.Description" @bind:event="oninput"
                                   @bind:after="MarkDirty" />
                        </div>
                    </div>

                    <div class="pem-entries-header">
                        <span class="pem-col-label">Entries</span>
                        <button class="pem-add-btn" @onclick="AddEntry">
                            <i class="bi bi-plus"></i>
                        </button>
                    </div>

                    <div class="pem-entries-list">
                        @foreach (var entry in _SelectedEnum.Entries)
                        {
                            var ent = entry;
                            <div class="pem-entry-row">
                                <input class="pem-input pem-entry-int" type="number"
                                       placeholder="0"
                                       value="@ent.IntValue"
                                       @onchange="e => { ent.IntValue = int.TryParse(e.Value?.ToString(), out int v) ? v : 0; MarkDirty(); }" />
                                <input class="pem-input pem-entry-str" type="text"
                                       placeholder="Male"
                                       @bind="ent.StringValue" @bind:event="oninput"
                                       @bind:after="MarkDirty" />
                                <button class="pem-entry-remove" @onclick="() => RemoveEntry(ent)">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        }

                        @if (_SelectedEnum.Entries.Count == 0)
                        {
                            <div class="pem-empty">No entries. Add at least one.</div>
                        }
                    </div>

                    <button class="pem-delete-enum-btn" @onclick="DeleteEnum">
                        <i class="bi bi-trash3"></i> Delete enum
                    </button>
                }
            </div>

        </div>

    </div>
}

@code {
    private bool         _Visible;
    private LocEnumDto?  _SelectedEnum;

    public void Show()
    {
        _SelectedEnum = null;
        _Visible      = true;
        StateHasChanged();
    }

    private void Close() => _Visible = false;

    private void SelectEnum(LocEnumDto e) => _SelectedEnum = e;

    private void AddEnum()
    {
        LocEnumDto e = new LocEnumDto { ProjectId = _ProjectState.CurrentProject!.Id };
        _ProjectState.CurrentProject!.Enums.Add(e);
        _SelectedEnum = e;
        
        _ProjectState.CurrentProject!.ProjectHistory.Add(new HistoryEntryDto
        {
            EntityPartName = "Enums",
            EntityPartId   = e.Id,
            ChangeType     = HistoryChangeType.Created,
            OldValue       = string.Empty,
            NewValue       = JsonConvert.SerializeObject(e),
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });
        
        MarkDirty();
    }

    private void DeleteEnum()
    {
        if (_SelectedEnum == null) return;
        _ProjectState.CurrentProject!.Enums.Remove(_SelectedEnum);
        
        _ProjectState.CurrentProject!.ProjectHistory.Add(new HistoryEntryDto
        {
            EntityPartName = "Enums",
            EntityPartId   = _SelectedEnum.Id,
            ChangeType     = HistoryChangeType.Deleted,
            OldValue       = JsonConvert.SerializeObject(_SelectedEnum),
            NewValue       = string.Empty,
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });
        
        _SelectedEnum = null;
        MarkDirty();
    }

    private void AddEntry()
    {
        if (_SelectedEnum == null) return;
        string oldEnum = JsonConvert.SerializeObject(_SelectedEnum);
        
        int next = _SelectedEnum.Entries.Count > 0
            ? _SelectedEnum.Entries.Max(e => e.IntValue) + 1 : 0;
        _SelectedEnum.Entries.Add(new LocEnumEntryDto { IntValue = next });
        
        _ProjectState.CurrentProject!.ProjectHistory.Add(new HistoryEntryDto
        {
            EntityPartName = "Enums",
            EntityPartId   = _SelectedEnum.Id,
            ChangeType     = HistoryChangeType.Updated,
            OldValue       = oldEnum,
            NewValue       = JsonConvert.SerializeObject(_SelectedEnum),
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });
        
        MarkDirty();
    }

    private void RemoveEntry(LocEnumEntryDto entry)
    {
        if (_SelectedEnum == null) return;
        string oldEnum = JsonConvert.SerializeObject(_SelectedEnum);
        _SelectedEnum.Entries.Remove(entry);
        
        _ProjectState.CurrentProject!.ProjectHistory.Add(new HistoryEntryDto
        {
            EntityPartName = "Enums",
            EntityPartId   = _SelectedEnum.Id,
            ChangeType     = HistoryChangeType.Updated,
            OldValue       = oldEnum,
            NewValue       = JsonConvert.SerializeObject(_SelectedEnum),
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });
        
        MarkDirty();
    }

    private void MarkDirty() => _ProjectState.MarkDirty();
}
