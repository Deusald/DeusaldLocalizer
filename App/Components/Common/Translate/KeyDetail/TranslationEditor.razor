@namespace App.Components.Translate
@using DeusaldLocalizerCommon
@using Newtonsoft.Json
@inject ProjectStateService _ProjectState

<div class="te-root">

    @if (_IsSourceLanguageSelected)
    {
        <div class="te-block">
            <div class="te-label-row">
                <label class="te-label">Source · @_SourceLangCode</label>
                <span class="te-hint">{placeholders} supported</span>
            </div>
            <textarea class="te-textarea @((_CanEditSource || _CanEditTranslation) ? "" : "te-readonly") @(_SourceOverLimit ? "te-over-limit" : "")"
                      @bind="_SourceDraft" @bind:event="oninput"
                      @bind:after="NotifyDraftChanged"
                      readonly="@(!_CanEditSource && !_CanEditTranslation)"
                      rows="4"
                      placeholder="Source text…"></textarea>
            @if (Key.MaxLength > 0)
            {
                <div class="te-char-count @(_SourceOverLimit ? "te-char-count-over" : "")">
                    @_SourceDraft.Length / @Key.MaxLength
                </div>
            }
        </div>

        @if (_CanEditSource)
        {
            <div class="te-actions">
                <button class="te-btn te-btn-primary" @onclick="SaveSourceText" disabled="@(!_HasSourceChanges || _SourceOverLimit)">
                    Save source
                </button>
                <button class="te-btn te-btn-ghost" @onclick="SuggestSourceText" disabled="@(!_HasSourceChanges || _SourceOverLimit)">
                    Suggest
                </button>
                <button class="te-btn te-btn-ghost" @onclick="ResetSourceDraft" disabled="@(!_HasSourceChanges)">
                    Reset
                </button>
            </div>
        }
        else if (_CanEditTranslation)
        {
            @* Contributor on the source language: can only propose, never save directly *@
            <div class="te-actions">
                <button class="te-btn te-btn-ghost" @onclick="SuggestSourceText" disabled="@(!_HasSourceChanges || _SourceOverLimit)">
                    Suggest
                </button>
                <button class="te-btn te-btn-ghost" @onclick="ResetSourceDraft" disabled="@(!_HasSourceChanges)">
                    Reset
                </button>
            </div>
        }
    }
    else
    {
        <div class="te-block">
            <label class="te-label">
                Source · @_SourceLangCode
                <span class="te-hint te-source-readonly-hint">read-only — switch to @_SourceLangCode to edit</span>
            </label>
            <textarea class="te-textarea te-readonly"
                      value="@_SourceDraft"
                      readonly
                      rows="3"
                      placeholder="Source text…"></textarea>
        </div>

        <div class="te-block">
            <div class="te-label-row">
                <label class="te-label">Translation · @SelectedLanguage</label>
                <span class="te-hint">{placeholders} supported</span>
            </div>
            <textarea class="te-textarea @(_CanEditTranslation ? "" : "te-readonly") @(_TranslationOverLimit ? "te-over-limit" : "")"
                      @bind="_TranslationDraft" @bind:event="oninput"
                      @bind:after="NotifyDraftChanged"
                      readonly="@(!_CanEditTranslation)"
                      rows="4"
                      placeholder="Type your translation…"></textarea>
            @if (Key.MaxLength > 0)
            {
                <div class="te-char-count @(_TranslationOverLimit ? "te-char-count-over" : "")">
                    @_TranslationDraft.Length / @Key.MaxLength
                </div>
            }
        </div>

        @if (_IsHashStale)
        {
            <div class="te-stale-warning">
                <i class="bi bi-exclamation-triangle"></i>
                Source has changed since this translation was last saved.
                @if (_CanConfirmMatch)
                {
                    <button class="te-source-matched-btn" @onclick="MarkSourceMatched">
                        Source matched
                    </button>
                }
            </div>
        }

        @if (_CanEditTranslation)
        {
            <div class="te-actions">
                @if (_IsAdmin || _IsReviewer)
                {
                    <button class="te-btn te-btn-primary" @onclick="SaveTranslation" disabled="@(!_HasTranslationChanges || _TranslationOverLimit)">
                        Save translation
                    </button>
                }
                <button class="te-btn te-btn-ghost" @onclick="SuggestTranslation" disabled="@(!_HasTranslationChanges || _TranslationOverLimit)">
                    Suggest
                </button>
                <button class="te-btn te-btn-ghost" @onclick="ResetTranslationDraft" disabled="@(!_HasTranslationChanges)">
                    Reset
                </button>
            </div>
        }
    }

</div>

@code {
    [Parameter] public LocalizationKeyDto                                 Key              { get; set; } = null!;
    [Parameter] public string                                             SelectedLanguage { get; set; } = "";
    [Parameter] public EventCallback                                      OnChanged        { get; set; }
    [Parameter] public EventCallback<(string source, string translation)> OnDraftChanged   { get; set; }

    private string _SourceDraft      = "";
    private string _TranslationDraft = "";
    private Guid?  _LoadedForKeyId;
    private string _LoadedForLanguage = "";

    // Snapshots of the last text we knew was saved on the DTO. Used to detect
    // external changes (e.g. a suggestion being accepted elsewhere) so the
    // draft can be re-synced, without clobbering genuine unsaved local edits.
    private string _LastKnownSourceText      = "";
    private string _LastKnownTranslationText = "";

    private string _SourceLangCode           => _ProjectState.CurrentProject!.MainLanguageId;
    private bool   _IsSourceLanguageSelected => SelectedLanguage == _SourceLangCode;

    private bool _IsAdmin         => _ProjectState.CurrentUserHas(PermissionFlags.Admin);
    private bool _IsContributor   => _ProjectState.CurrentUserHas(PermissionFlags.Contributor);
    private bool _IsReviewer      => _ProjectState.CurrentUserHas(PermissionFlags.Reviewer);
    private bool _CanConfirmMatch => _ProjectState.CurrentUserHas(PermissionFlags.Reviewer) || _ProjectState.CurrentUserHas(PermissionFlags.Admin);

    /// <summary>Only meaningful when the source language is selected — admin can edit and save it directly.</summary>
    private bool _CanEditSource => _IsAdmin;

    /// <summary>Only meaningful when a non-source language is selected.</summary>
    private bool _CanEditTranslation => _IsReviewer || _IsContributor || _IsAdmin;

    protected override void OnParametersSet()
    {
        bool keyOrLanguageChanged = _LoadedForKeyId != Key.Id || _LoadedForLanguage != SelectedLanguage;

        TranslationDto? source            = Key.Translations.Find(t => t.LanguageId == _SourceLangCode);
        string          currentSourceText = source?.Text ?? "";

        TranslationDto? translation            = Key.Translations.Find(t => t.LanguageId == SelectedLanguage);
        string          currentTranslationText = translation?.Text ?? "";

        // Snapshot drafts before any mutations so we can detect if they changed
        string previousSourceDraft      = _SourceDraft;
        string previousTranslationDraft = _TranslationDraft;

        if (keyOrLanguageChanged)
        {
            _SourceDraft      = currentSourceText;
            _TranslationDraft = currentTranslationText;

            _LoadedForKeyId    = Key.Id;
            _LoadedForLanguage = SelectedLanguage;
        }
        else
        {
            // Same key/language as before — if the saved text changed since we
            // last saw it (e.g. a suggestion was accepted elsewhere) and the
            // draft still matches what we last knew, it's safe to resync.
            // If the draft differs from what we last knew, the user has typed
            // something unsaved, so leave their draft alone.
            if (currentSourceText != _LastKnownSourceText && _SourceDraft == _LastKnownSourceText)
                _SourceDraft = currentSourceText;

            if (currentTranslationText != _LastKnownTranslationText && _TranslationDraft == _LastKnownTranslationText)
                _TranslationDraft = currentTranslationText;
        }

        _LastKnownSourceText      = currentSourceText;
        _LastKnownTranslationText = currentTranslationText;

        // Only notify the parent if drafts actually changed here — calling
        // InvokeAsync unconditionally triggers a parent StateHasChanged on
        // every render, which re-renders this component, which fires
        // OnParametersSet again: an infinite loop.
        if (_SourceDraft != previousSourceDraft || _TranslationDraft != previousTranslationDraft)
            OnDraftChanged.InvokeAsync((_SourceDraft, _TranslationDraft));
    }

    private async Task NotifyDraftChanged()
    {
        await OnDraftChanged.InvokeAsync((_SourceDraft, _TranslationDraft));
    }

    private bool _SourceOverLimit =>
        Key.MaxLength > 0 && _SourceDraft.Length > Key.MaxLength;

    private bool _TranslationOverLimit =>
        Key.MaxLength > 0 && _TranslationDraft.Length > Key.MaxLength;

    /// <summary>True when the translation's BaseTextHash no longer matches the current source hash.</summary>
    private bool _IsHashStale
    {
        get
        {
            if (_IsSourceLanguageSelected) return false;
            TranslationDto? t = Key.Translations.Find(tr => tr.LanguageId == SelectedLanguage);
            if (t == null || string.IsNullOrEmpty(t.BaseTextHash)) return false;
            TranslationDto? src = Key.Translations.Find(tr => tr.LanguageId == _SourceLangCode);
            return t.BaseTextHash != TextHashHelper.Compute(src?.Text ?? "");
        }
    }

    private bool _HasSourceChanges
    {
        get
        {
            TranslationDto? current = Key.Translations.Find(t => t.LanguageId == _SourceLangCode);
            return (current?.Text ?? "") != _SourceDraft;
        }
    }

    private bool _HasTranslationChanges
    {
        get
        {
            TranslationDto? current = Key.Translations.Find(t => t.LanguageId == SelectedLanguage);
            return (current?.Text ?? "") != _TranslationDraft;
        }
    }

    private void ResetSourceDraft()
    {
        TranslationDto? current = Key.Translations.Find(t => t.LanguageId == _SourceLangCode);
        _SourceDraft = current?.Text ?? "";
    }

    private void ResetTranslationDraft()
    {
        TranslationDto? current = Key.Translations.Find(t => t.LanguageId == SelectedLanguage);
        _TranslationDraft = current?.Text ?? "";
    }

    private async Task SaveSourceText()
    {
        if (!_CanEditSource) return;

        TranslationDto? source = Key.Translations.Find(t => t.LanguageId == _SourceLangCode);
        if (source == null)
        {
            source = new TranslationDto { KeyId = Key.Id, LanguageId = _SourceLangCode };
            Key.Translations.Add(source);
        }
        if (source.Text == _SourceDraft) return;

        string oldText = source.Text;
        string oldHash = TextHashHelper.Compute(oldText);
        string newHash = TextHashHelper.Compute(_SourceDraft);

        source.Text      = _SourceDraft;
        source.UpdatedBy = _ProjectState.CurrentUser.Id;
        source.UpdatedAt = DateTime.UtcNow;
        source.Status    = TranslationStatus.Approved;

        // Update the source's own hash (it's always considered "matching itself")
        source.BaseTextHash = newHash;

        // Mark every other-language translation as needing attention if their
        // BaseTextHash was based on the old source and the source actually changed.
        if (oldHash != newHash)
        {
            foreach (TranslationDto other in Key.Translations)
            {
                if (other.LanguageId == _SourceLangCode) continue;
                // Only flag if it had a hash recorded (i.e. was based on some source version)
                if (!string.IsNullOrEmpty(other.BaseTextHash))
                {
                    other.NeedsAttention = true;
                }
            }
        }

        Key.History.Add(new HistoryEntryDto
        {
            EntityPartName = $"Translation-Text/{source.LanguageId}",
            EntityPartId   = source.Id,
            ChangeType     = HistoryChangeType.Updated,
            OldValue       = oldText,
            NewValue       = source.Text,
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });

        Key.UpdatedAt = DateTime.UtcNow;
        _ProjectState.MarkDirty();
        await OnChanged.InvokeAsync();
    }

    private async Task SuggestSourceText()
    {
        if (!_CanEditTranslation) return;

        TranslationDto? translation = Key.Translations.Find(t => t.LanguageId == _SourceLangCode);
        if (translation == null)
        {
            translation = new TranslationDto { KeyId = Key.Id, LanguageId = _SourceLangCode };
            Key.Translations.Add(translation);
        }

        translation.NeedsAttention = true;
        if (translation.Status == TranslationStatus.Draft) translation.Status = TranslationStatus.Suggested;

        SuggestionDto suggestionDto = new SuggestionDto
        {
            KeyId         = Key.Id,
            TranslationId = translation.Id,
            Text          = _SourceDraft,
            AuthorId      = _ProjectState.CurrentUser.Id,
            AuthorName    = _ProjectState.CurrentUser.DisplayName,
            Status        = SuggestionStatus.Pending,
        };

        translation.Suggestions.Add(suggestionDto);

        Key.History.Add(new HistoryEntryDto
        {
            EntityPartName = $"Translation-Suggestion/{translation.LanguageId}",
            EntityPartId   = translation.Id,
            ChangeType     = HistoryChangeType.Created,
            OldValue       = string.Empty,
            NewValue       = JsonConvert.SerializeObject(suggestionDto),
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });

        Key.UpdatedAt = DateTime.UtcNow;
        _ProjectState.MarkDirty();
        await OnChanged.InvokeAsync();
    }

    private async Task SaveTranslation()
    {
        if (!_CanEditTranslation) return;

        TranslationDto? translation = Key.Translations.Find(t => t.LanguageId == SelectedLanguage);
        if (translation == null)
        {
            translation = new TranslationDto { KeyId = Key.Id, LanguageId = SelectedLanguage };
            Key.Translations.Add(translation);
        }

        string oldText = translation.Text;

        translation.Text           = _TranslationDraft;
        translation.UpdatedBy      = _ProjectState.CurrentUser.Id;
        translation.UpdatedAt      = DateTime.UtcNow;
        translation.NeedsAttention = false;

        // Record which version of the source this translation was based on
        TranslationDto? currentSource = Key.Translations.Find(t => t.LanguageId == _SourceLangCode);
        translation.BaseTextHash = TextHashHelper.Compute(currentSource?.Text ?? "");

        Key.History.Add(new HistoryEntryDto
        {
            EntityPartName = $"Translation-Text/{translation.LanguageId}",
            EntityPartId   = translation.Id,
            ChangeType     = HistoryChangeType.Updated,
            OldValue       = oldText,
            NewValue       = translation.Text,
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });

        // Contributors without Reviewer/Admin leave it as Draft; reviewers/admins approve directly.
        translation.Status = (_ProjectState.CurrentUserHas(PermissionFlags.Reviewer)
                              || _ProjectState.CurrentUserHas(PermissionFlags.Admin))
                                 ? TranslationStatus.Approved
                                 : TranslationStatus.Draft;

        Key.UpdatedAt = DateTime.UtcNow;
        _ProjectState.MarkDirty();
        await OnChanged.InvokeAsync();
    }

    private async Task MarkSourceMatched()
    {
        if (!_CanConfirmMatch) return;

        TranslationDto? translation = Key.Translations.Find(t => t.LanguageId == SelectedLanguage);
        if (translation == null) return;

        TranslationDto? src = Key.Translations.Find(t => t.LanguageId == _SourceLangCode);
        translation.BaseTextHash   = TextHashHelper.Compute(src?.Text ?? "");
        translation.NeedsAttention = false;
        translation.UpdatedAt      = DateTime.UtcNow;

        Key.History.Add(new HistoryEntryDto
        {
            EntityPartName = $"Translation-Hash/{translation.LanguageId}",
            EntityPartId   = translation.Id,
            ChangeType     = HistoryChangeType.Updated,
            OldValue       = string.Empty,
            NewValue       = "Source confirmed as still accurate",
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });

        Key.UpdatedAt = DateTime.UtcNow;
        _ProjectState.MarkDirty();
        await OnChanged.InvokeAsync();
    }

    private async Task SuggestTranslation()
    {
        if (!_CanEditTranslation) return;

        TranslationDto? translation = Key.Translations.Find(t => t.LanguageId == SelectedLanguage);
        if (translation == null)
        {
            translation = new TranslationDto { KeyId = Key.Id, LanguageId = SelectedLanguage };
            Key.Translations.Add(translation);
        }

        translation.NeedsAttention = true;
        if (translation.Status == TranslationStatus.Draft) translation.Status = TranslationStatus.Suggested;

        SuggestionDto suggestionDto = new SuggestionDto
        {
            KeyId         = Key.Id,
            TranslationId = translation.Id,
            Text          = _TranslationDraft,
            AuthorId      = _ProjectState.CurrentUser.Id,
            AuthorName    = _ProjectState.CurrentUser.DisplayName,
            Status        = SuggestionStatus.Pending,
        };

        translation.Suggestions.Add(suggestionDto);

        Key.History.Add(new HistoryEntryDto
        {
            EntityPartName = $"Translation-Suggestion/{translation.LanguageId}",
            EntityPartId   = translation.Id,
            ChangeType     = HistoryChangeType.Created,
            OldValue       = string.Empty,
            NewValue       = JsonConvert.SerializeObject(suggestionDto),
            UserId         = _ProjectState.CurrentUser.Id,
            UserName       = _ProjectState.CurrentUser.DisplayName
        });

        Key.UpdatedAt = DateTime.UtcNow;
        _ProjectState.MarkDirty();
        await OnChanged.InvokeAsync();
    }

}