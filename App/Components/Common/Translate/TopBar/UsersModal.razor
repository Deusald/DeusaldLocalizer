@namespace App.Components.Translate
@using DeusaldLocalizerCommon
@using DeusaldSharp
@inject ProjectStateService _ProjectState

@if (_Visible)
{
    <div class="um-backdrop" @onclick="Close"></div>

    <div class="um-box" @onclick:stopPropagation="true">

        <div class="um-header">
            <span class="um-title">Collaborators</span>
            <button class="um-close" @onclick="Close"><i class="bi bi-x-lg"></i></button>
        </div>

        @if (_ProjectState.BackendService.IsOnline)
        {
            <div class="um-section">
                <div class="um-section-label">Your account</div>
                <div class="um-password-row">
                    <input class="um-input" type="password" placeholder="New password"
                           @bind="_NewPassword" @bind:event="oninput"/>
                    <button class="um-btn um-btn-primary" @onclick="ChangePassword" disabled="@(string.IsNullOrWhiteSpace(_NewPassword))">
                        Update
                    </button>
                </div>
                @if (_PasswordMessage is not null)
                {
                    <div class="um-password-msg">@_PasswordMessage</div>
                }
            </div>
        }

        <div class="um-section">
            <div class="um-section-header">
                <span class="um-section-label">Members (@_ProjectState.CurrentProject!.Members.Count)</span>
                @if (_IsSuperAdmin)
                {
                    <label class="um-accept-toggle" title="Allow new members to join">
                        <input type="checkbox"
                               checked="@_ProjectState.CurrentProject.AcceptNewMembers"
                               @onchange="ToggleAcceptNewMembers"/>
                        <span class="um-accept-label">Accept new members</span>
                    </label>
                }
            </div>

            <div class="um-member-list">
                @foreach (ProjectMemberDto member in _ProjectState.CurrentProject.Members)
                {
                    bool   isSelf      = member.UserId == _ProjectState.CurrentUser.Id;
                    string joinedTitle = $"Joined {member.JoinedAt:MMM d, yyyy}";

                    <div class="um-member-row">
                        <div class="um-member-avatar" style="background:@AvatarColor(member.UserId)"
                             title="@joinedTitle">
                            @Initial(member.DisplayName)
                        </div>
                        <div class="um-member-info">
                            <div class="um-member-name">
                                @member.DisplayName
                                @if (isSelf)
                                {
                                    <span class="um-member-you">you</span>
                                }
                            </div>
                            @if (member.IsSuperAdmin || !_IsAdmin)
                            {
                                <div class="um-perm-readonly">@PermissionsSummary(member.Permissions, member.IsSuperAdmin)</div>
                            }
                            else
                            {
                                <div class="um-perm-flags">
                                    @foreach (PermissionFlags flag in EnumExtensions.IterateAllValues<PermissionFlags>())
                                    {
                                        if (!flag.IsSingleFlagOn()) continue;
                                        bool active = (member.Permissions & flag) == flag;
                                        <button class="um-perm-chip @(active ? "active" : "")"
                                                @onclick="() => TogglePermission(member, flag)"
                                                title="@flag">
                                            @FlagLabel(flag, member.IsSuperAdmin)
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        @if (_IsAdmin && !isSelf)
                        {
                            <button class="um-remove-btn" title="Remove access" @onclick="() => RemoveMember(member)">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

    </div>
}

@code {
    private bool    _Visible;
    private string  _NewPassword = "";
    private string? _PasswordMessage;

    private bool _IsAdmin      => _ProjectState.CurrentUserHas(PermissionFlags.Admin);
    private bool _IsSuperAdmin => _ProjectState.IsCurrentUserSuperAdmin();

    public void Show()
    {
        _NewPassword     = "";
        _PasswordMessage = null;
        _Visible         = true;
        StateHasChanged();
    }

    private void Close() => _Visible = false;

    private static string Initial(string name) =>
        string.IsNullOrEmpty(name) ? "?" : name.Substring(0, 1).ToUpper();

    private static readonly string[] _AvatarPalette =
        ["#5b6cff", "#3ad98a", "#ff6b6b", "#f5a623", "#a78bfa", "#36c5f0"];

    private static string AvatarColor(Guid userId)
    {
        int idx = Math.Abs(userId.GetHashCode()) % _AvatarPalette.Length;
        return _AvatarPalette[idx];
    }

    private static string FlagLabel(PermissionFlags flag, bool superAdmin) => flag switch
    {
        PermissionFlags.Vote    => "Voter",
        PermissionFlags.Suggest => "Contributor",
        PermissionFlags.Review  => "Reviewer",
        PermissionFlags.Admin   => superAdmin ? "Super Admin" : "Admin",
        _                       => flag.ToString(),
    };

    private static string PermissionsSummary(PermissionFlags flags, bool superAdmin)
    {
        if (flags == PermissionFlags.None) return "No access";
        List<string> labels = new List<string>();
        foreach (PermissionFlags f in EnumExtensions.IterateAllValues<PermissionFlags>())
        {
            if (!f.IsSingleFlagOn()) continue;
            if ((flags & f) == f) labels.Add(FlagLabel(f, superAdmin));
        }

        return string.Join(", ", labels);
    }

    private void ToggleAcceptNewMembers(ChangeEventArgs e)
    {
        _ProjectState.BackendService.SetAcceptNewMembersAsync((bool)(e.Value ?? false)).Forget();
    }

    private void TogglePermission(ProjectMemberDto member, PermissionFlags flag)
    {
        if (!_IsSuperAdmin && flag == PermissionFlags.Admin) return;
        PermissionFlags newPermissions = (member.Permissions & flag) == flag
                                             ? member.Permissions & ~flag
                                             : member.Permissions | flag;
        if ((newPermissions & PermissionFlags.Admin) != 0) newPermissions = PermissionFlags.All;

        _ProjectState.BackendService.SetNewUserPermissionsAsync(member, newPermissions).Forget();
    }

    private void RemoveMember(ProjectMemberDto member)
    {
        _ProjectState.BackendService.RemoveUserAsync(member).Forget();
    }

    private async void ChangePassword()
    {
        if (string.IsNullOrWhiteSpace(_NewPassword)) return;
        (bool, string) result = await _ProjectState.BackendService.OnlineChangePasswordAsync(_NewPassword);
        if (result.Item1)
        {
            _PasswordMessage = "Password updated.";
            _NewPassword     = "";
        }
        else _PasswordMessage = result.Item2;
    }

}
