@namespace App.Components.Translate
@using CommunityToolkit.Maui.Storage
@using System.IO
@using DeusaldLocalizerCommon
@inject ProjectStateService _ProjectState
@inject DlocFileService     _DlocService
@inject NavigationManager   _Nav

@{ if (!_ProjectState.HasProject) return; }

<div class="ttb-root">

    <div class="ttb-left">
        <button class="ttb-back-btn" @onclick="GoHome" title="Back to projects">
            <i class="bi bi-chevron-left"></i>
        </button>

        <div class="ttb-logo-orbs">
            <div class="ttb-orb ttb-orb-1"></div>
            <div class="ttb-orb ttb-orb-2"></div>
            <div class="ttb-orb ttb-orb-3"></div>
        </div>
        <span class="ttb-project-name">@_ProjectState.CurrentProject!.Name</span>
        <span class="ttb-sep">/</span>
        <span class="ttb-translating">
            Translating into <strong>@_LanguageLabel</strong>
        </span>
    </div>

    <div class="ttb-right">

        @if (_ProjectState.IsOnline)
        {
            <span class="ttb-status-pill @(_ProjectState.IsDirty ? "ttb-status-warn" : "ttb-status-ok")">
                <span class="ttb-status-dot"></span>
                @(_ProjectState.IsDirty ? "Syncing…" : "Synced")
            </span>
        }
        else
        {
            @if (_ProjectState.IsDirty)
            {
                <button class="ttb-save-btn" @onclick="Save">
                    <i class="bi bi-cloud-arrow-up"></i> Save
                </button>
            }
            <span class="ttb-status-pill @(_ProjectState.IsDirty ? "ttb-status-warn" : "ttb-status-ok")">
                <span class="ttb-status-dot"></span>
                @(_ProjectState.IsDirty ? "Unsaved" : "Saved")
            </span>
        }

        @if (_ProjectState.CurrentUserHas(PermissionFlags.Admin))
        {
            <button class="ttb-history-btn" @onclick="() => _ProjectHistoryModal?.Show()" title="Project history">
                <i class="bi bi-clock-history"></i>
            </button>
        }

        <div class="ttb-avatars" @onclick="OpenUsersModal">
            @foreach (ProjectMemberDto member in _VisibleMembers)
            {
                <div class="ttb-avatar" style="background:@AvatarColor(member.UserId)" title="@member.DisplayName">
                    @Initial(member.DisplayName)
                </div>
            }
            @if (_ExtraMemberCount > 0)
            {
                <div class="ttb-avatar ttb-avatar-extra">+@_ExtraMemberCount</div>
            }
        </div>

    </div>

</div>

<UsersModal @ref="_UsersModal"/>
<ConfirmLeaveModal @ref="_ConfirmLeaveModal" OnSaveAndLeave="SaveAndLeave" OnDiscardAndLeave="DiscardAndLeave"/>
<ProjectHistoryModal @ref="_ProjectHistoryModal"/>

@code {
    [Parameter] public string SelectedLanguage { get; set; } = "";

    private UsersModal?          _UsersModal;
    private ConfirmLeaveModal?   _ConfirmLeaveModal;
    private ProjectHistoryModal? _ProjectHistoryModal;

    private const int _MAX_VISIBLE_AVATARS = 3;

    private string _LanguageLabel
    {
        get
        {
            CultureEntry? entry = CultureService.FindByCode(SelectedLanguage);
            return entry?.EnglishName ?? SelectedLanguage;
        }
    }

    private List<ProjectMemberDto> _VisibleMembers =>
        _ProjectState.CurrentProject!.Members.Count <= _MAX_VISIBLE_AVATARS
            ? _ProjectState.CurrentProject.Members
            : _ProjectState.CurrentProject.Members.GetRange(0, _MAX_VISIBLE_AVATARS);

    private int _ExtraMemberCount =>
        Math.Max(0, _ProjectState.CurrentProject!.Members.Count - _MAX_VISIBLE_AVATARS);

    private static string Initial(string name) =>
        string.IsNullOrEmpty(name) ? "?" : name.Substring(0, 1).ToUpper();

    private static readonly string[] _AvatarPalette =
        { "#5b6cff", "#3ad98a", "#ff6b6b", "#f5a623", "#a78bfa", "#36c5f0" };

    private static string AvatarColor(Guid userId)
    {
        int idx = Math.Abs(userId.GetHashCode()) % _AvatarPalette.Length;
        return _AvatarPalette[idx];
    }

    protected override void OnInitialized()
    {
        _ProjectState.DirtyStateChanged += OnDirty;
    }

    private void OpenUsersModal() => _UsersModal?.Show();

    private void GoHome()
    {
        if (_ProjectState.IsDirty && !_ProjectState.IsOnline)
        {
            _ConfirmLeaveModal?.Show();
        }
        else
        {
            LeaveAndUnload();
        }
    }

    private void LeaveAndUnload()
    {
        _ProjectState.CloseProject();
        _Nav.NavigateTo("/");
    }

    private async Task SaveAndLeave()
    {
        await SaveCore();
        LeaveAndUnload();
    }

    private void DiscardAndLeave()
    {
        LeaveAndUnload();
    }

    private async Task Save()
    {
        await SaveCore();
    }

    private async Task SaveCore()
    {
        ProjectDto project = _ProjectState.CurrentProject!;

        if (string.IsNullOrEmpty(_ProjectState.CurrentFilePath))
        {
            // Never saved to disk yet — ask where to put it.
            using MemoryStream stream = new MemoryStream();
            await _DlocService.SaveToStreamAsync(project, stream);
            stream.Position = 0;

            string          fileName = string.IsNullOrEmpty(project.Slug) ? "project" : project.Slug;
            FileSaverResult result   = await FileSaver.Default.SaveAsync($"{fileName}{DlocFileService.FILE_EXTENSION}", stream);
            if (result.IsSuccessful)
            {
                _ProjectState.UpdateFilePath(result.FilePath);
                _ProjectState.MarkClean();
            }
        }
        else
        {
            await _DlocService.SaveAsync(project, _ProjectState.CurrentFilePath);
            _ProjectState.MarkClean();
        }

        if (!string.IsNullOrEmpty(_ProjectState.CurrentFilePath)) RecentProjectsService.UpdateRecentProjects(project, _ProjectState.CurrentFilePath!);
        StateHasChanged();
    }

    private void OnDirty()
    {
        InvokeAsync(StateHasChanged);
    }
    
    public void Dispose()
    {
        _ProjectState.DirtyStateChanged -= OnDirty;
    }

}
