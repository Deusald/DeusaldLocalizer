@namespace App.Components.Translate
@using DeusaldLocalizerCommon
@inject ProjectStateService _ProjectState
@implements IDisposable

<div class="lc-root">

    @if (!_AddMode)
    {
        <div class="lc-search-wrap">
            <i class="bi bi-search lc-search-icon"></i>
            <input class="lc-search" type="text" placeholder="Search languages…"
                   @bind="_Filter" @bind:event="oninput"/>
        </div>

        <div class="lc-list">
            @foreach (string code in _FilteredLanguages)
            {
                CultureEntry? entry  = CultureService.FindByCode(code);
                bool          active = code == SelectedLanguage;
                bool          isMain = code == _ProjectState.CurrentProject!.MainLanguageId;
                int           pct    = ProgressFor(code);

                @if (_EditMode)
                {
                    <div class="lc-item lc-item-editing">
                        <div class="lc-item-top">
                            <span class="lc-item-flag">@(entry?.FlagEmoji ?? "🌐")</span>
                            <span class="lc-item-name">@(entry?.ShortName ?? code)</span>
                            @if (isMain)
                            {
                                <span class="lc-item-main-badge">SRC</span>
                            }
                            @if (!isMain)
                            {
                                <button class="lc-item-remove" title="Remove language" @onclick="() => RemoveLanguage(code)">
                                    <i class="bi bi-x"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <button class="lc-item @(active ? "active" : "")" @onclick="() => OnLanguageSelected.InvokeAsync(code)">
                        <div class="lc-item-top">
                            <span class="lc-item-flag">@(entry?.FlagEmoji ?? "🌐")</span>
                            <span class="lc-item-name">@(entry?.ShortName ?? code)</span>
                            @if (isMain)
                            {
                                <span class="lc-item-main-badge">SRC</span>
                            }
                            <span class="lc-item-pct">@pct%</span>
                        </div>
                        <div class="lc-item-bar">
                            <div class="lc-item-fill" style="width:@pct%"></div>
                        </div>
                    </button>
                }
            }
        </div>

        @if (_IsAdmin)
        {
            @if (_EditMode)
            {
                <button class="lc-cancel-btn" @onclick="() => _EditMode = false">Done</button>
            }
            else
            {
                <div class="lc-bottom-actions">
                    <button class="lc-add-btn" @onclick="EnterAddMode">
                        <i class="bi bi-plus-lg"></i> Add language
                    </button>
                    <button class="lc-edit-btn" @onclick="() => _EditMode = true" title="Edit languages">
                        <i class="bi bi-pencil"></i>
                    </button>
                </div>
            }
        }
    }
    else
    {
        <div class="lc-add-header">
            <span class="lc-add-title">Add language</span>
        </div>

        <div class="lc-search-wrap">
            <i class="bi bi-search lc-search-icon"></i>
            <input class="lc-search" type="text" placeholder="Search by name or code…"
                   @bind="_AddQuery" @bind:event="oninput"/>
        </div>

        <div class="lc-add-results">
            @{ HashSet<string> existing = new HashSet<string>(_ProjectState.CurrentProject!.Languages); }
            @{ List<CultureEntry> hits = CultureService.Search(_AddQuery).Where(c => !existing.Contains(c.Code)).ToList(); }
            @if (hits.Count == 0)
            {
                <div class="lc-add-empty">No results.</div>
            }
            else
            {
                @foreach (CultureEntry c in hits.Take(100))
                {
                    CultureEntry entry = c;
                    <button class="lc-add-item" @onclick="() => AddLanguage(entry.Code)">
                        <span class="lc-add-flag">@entry.FlagEmoji</span>
                        <span class="lc-add-name">@entry.EnglishName</span>
                        <span class="lc-add-code">@entry.Code</span>
                        <i class="bi bi-plus lc-add-plus"></i>
                    </button>
                }
            }
        </div>

        <button class="lc-cancel-btn" @onclick="ExitAddMode">Cancel</button>
    }

</div>

@code {
    [Parameter] public string                SelectedLanguage   { get; set; } = "";
    [Parameter] public EventCallback<string> OnLanguageSelected { get; set; }

    private string _Filter = "";
    private bool   _AddMode;
    private bool   _EditMode;
    private string _AddQuery = "";

    private bool _IsAdmin => _ProjectState.CurrentUserHas(PermissionFlags.Admin);

    protected override void OnInitialized()
    {
        _ProjectState.ProjectDataChanged += OnProjectDataChanged;
    }

    private IEnumerable<string> _FilteredLanguages
    {
        get
        {
            IEnumerable<string> langs = _ProjectState.CurrentProject!.Languages.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_Filter))
            {
                string q = _Filter.Trim().ToLowerInvariant();
                langs = langs.Where(code =>
                {
                    CultureEntry? entry = CultureService.FindByCode(code);
                    return code.ToLowerInvariant().Contains(q)
                           || (entry != null && entry.EnglishName.ToLowerInvariant().Contains(q));
                });
            }
            return langs;
        }
    }

    private int ProgressFor(string code)
    {
        ProjectDto project = _ProjectState.CurrentProject!;
        if (code == project.MainLanguageId) return 100;
        int keyCount = project.Keys.Count;
        if (keyCount == 0) return 0;
        int translated = project.Keys
                                 .SelectMany(k => k.Translations)
                                 .Count(t => t.LanguageId == code && t.Status == TranslationStatus.Approved && !string.IsNullOrEmpty(t.Text));
        return (int)Math.Round(translated * 100.0 / keyCount);
    }

    private void EnterAddMode()
    {
        _AddQuery = "";
        _AddMode  = true;
    }

    private void ExitAddMode()
    {
        _AddMode = false;
    }

    private void AddLanguage(string code)
    {
        ProjectDto project = _ProjectState.CurrentProject!;
        if (project.Languages.Contains(code)) return;
        project.Languages.Add(code);
        if (project.Languages.Count == 1) project.MainLanguageId = code;
        _ProjectState.MarkDirty();
        ExitAddMode();
    }

    private async Task RemoveLanguage(string code)
    {
        ProjectDto project = _ProjectState.CurrentProject!;
        if (code == project.MainLanguageId) return; // main language can't be removed

        // Only hide the language from the project — existing translations for
        // this code are intentionally left untouched on each key, so the data
        // reappears automatically if the language is added back later.
        project.Languages.Remove(code);
        _ProjectState.MarkDirty();

        if (SelectedLanguage == code)
        {
            string fallback = project.Languages.Find(l => l != project.MainLanguageId)
                           ?? project.MainLanguageId;
            await OnLanguageSelected.InvokeAsync(fallback);
        }
    }

    private void OnProjectDataChanged()
    {
        InvokeAsync(StateHasChanged);
    }
    
    public void Dispose()
    {
        _ProjectState.ProjectDataChanged -= OnProjectDataChanged;
    }
}