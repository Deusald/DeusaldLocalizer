@page "/languages"
@using DeusaldLocalizerCommon
@using global::App.Components.Layout
@layout MainLayout
@inject ProjectStateService _ProjectState
@inject NavigationManager   _Nav

@if (!_ProjectState.HasProject)
{
    <div style="padding:2rem;color:var(--dl-text-2)">No project open.</div>
    return;
}

<div class="lang-page">

    @* ── Page header ──────────────────────────────────────────────────────── *@
    <div class="lang-header">
        <div>
            <h2 class="lang-title">Languages</h2>
            <p class="lang-subtitle">
                @_ProjectState.CurrentProject!.Languages.Count language@(_ProjectState.CurrentProject.Languages.Count == 1 ? "" : "s") ·
                main language: @MainCultureLabel
            </p>
        </div>

        <button class="lang-add-btn" @onclick="OpenAddPanel" disabled="@_ShowAddPanel">
            <i class="bi bi-plus-lg"></i> Add language
        </button>
    </div>

    <div class="lang-body">

        @* ── Language list ─────────────────────────────────────────────────── *@
        <div class="lang-list">
            @if (_ProjectState.CurrentProject.Languages.Count == 0)
            {
                <div class="lang-empty">No languages yet. Add one to get started.</div>
            }
            else
            {
                @foreach (string codeId in _ProjectState.CurrentProject.Languages)
                {
                    CultureEntry?  entry    = CultureService.FindByCode(codeId);
                    bool isMain   = codeId == _ProjectState.CurrentProject.MainLanguageId;
                    int  keyCount = _ProjectState.CurrentProject.Keys.Count;
                    int translated = keyCount > 0
                                         ? _ProjectState.CurrentProject.Keys
                                                        .SelectMany(k => k.Translations)
                                                        .Count(t => t.LanguageId == codeId && !string.IsNullOrEmpty(t.Text))
                                         : 0;
                    int pct = keyCount > 0 ? (int)Math.Round(translated * 100.0 / keyCount) : 0;

                    <div class="lang-row @(isMain ? "lang-row-main" : "")">
                        <div class="lang-row-flag">
                            @(entry?.FlagEmoji ?? "🌐")
                        </div>
                        <div class="lang-row-info">
                            <div class="lang-row-name">
                                @(entry?.EnglishName ?? codeId)
                                @if (isMain)
                                {
                                    <span class="lang-badge-main">MAIN</span>
                                }
                            </div>
                            <div class="lang-row-code">@codeId</div>
                        </div>

                        @if (!isMain && keyCount > 0)
                        {
                            <div class="lang-row-progress">
                                <div class="lang-row-progress-top">
                                    <span>@translated / @keyCount</span>
                                    <span class="lang-row-pct">@pct%</span>
                                </div>
                                <div class="lang-row-bar">
                                    <div class="lang-row-fill" style="width:@pct%"></div>
                                </div>
                            </div>
                        }
                        else if (isMain)
                        {
                            <div class="lang-row-source-note">Source language</div>
                        }

                        <div class="lang-row-actions">
                            @if (!isMain)
                            {
                                <button class="lang-icon-btn" title="Set as main language"
                                        @onclick="() => SetMain(codeId)">
                                    <i class="bi bi-star"></i>
                                </button>
                                <button class="lang-icon-btn lang-icon-btn-danger" title="Remove language"
                                        @onclick="() => RemoveLanguage(codeId)">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        @* ── Add language panel ────────────────────────────────────────────── *@
        @if (_ShowAddPanel)
        {
            <div class="lang-add-panel">
                <div class="lang-add-panel-header">
                    <span class="lang-add-panel-title">Add language</span>
                    <button class="lang-icon-btn" @onclick="CloseAddPanel">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="lang-add-search-wrap">
                    <i class="bi bi-search lang-add-search-icon"></i>
                    <input class="lang-add-search"
                           type="text"
                           placeholder="Search by name or code…"
                           @bind="_AddQuery"
                           @bind:event="oninput"
                           @ref="_AddSearchInput"/>
                </div>

                <div class="lang-add-results">
                    @{ HashSet<string> existing = new System.Collections.Generic.HashSet<string>(_ProjectState.CurrentProject!.Languages); }
                    @{ List<CultureEntry> hits = CultureService.Search(_AddQuery).Where(c => !existing.Contains(c.Code)).ToList(); }
                    @if (hits.Count == 0)
                    {
                        <div class="lang-add-empty">
                            @(existing.Count == CultureService.All.Count ? "All languages added." : "No results.")
                        </div>
                    }
                    else
                    {
                        @foreach (CultureEntry c in hits.Take(100))
                        {
                            CultureEntry entry = c;
                            <button class="lang-add-item" @onclick="() => AddLanguage(entry.Code)">
                                <span class="lang-add-flag">@entry.FlagEmoji</span>
                                <span class="lang-add-name">@entry.EnglishName</span>
                                <span class="lang-add-code">@entry.Code</span>
                                <i class="bi bi-plus lang-add-plus"></i>
                            </button>
                        }
                    }
                </div>
            </div>
        }

    </div>

    @if (_Error is not null)
    {
        <div class="dl-alert dl-alert-error" style="margin:1rem 1.5rem 0;">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@_Error</span>
        </div>
    }

</div>

@code {
    private bool    _ShowAddPanel;
    private string  _AddQuery = "";
    private string? _Error;

    private ElementReference _AddSearchInput;

    private string MainCultureLabel
    {
        get
        {
            string? code = _ProjectState.CurrentProject?.MainLanguageId;
            if (code is null) return "—";
            return CultureService.FindByCode(code)?.EnglishName ?? code;
        }
    }

    private void OpenAddPanel()
    {
        _AddQuery     = "";
        _ShowAddPanel = true;
    }

    private void CloseAddPanel()
    {
        _ShowAddPanel = false;
        _AddQuery     = "";
    }

    private void AddLanguage(string code)
    {
        ProjectDto project = _ProjectState.CurrentProject!;
        if (project.Languages.Contains(code)) return;

        project.Languages.Add(code);

        // If this is the first language, make it the main one
        if (project.Languages.Count == 1)
            project.MainLanguageId = code;

        _ProjectState.MarkDirty();
        _AddQuery = "";
    }

    private void RemoveLanguage(string code)
    {
        ProjectDto project = _ProjectState.CurrentProject!;
        if (code == project.MainLanguageId)
        {
            _Error = "Cannot remove the main language. Set a different main language first.";
            return;
        }

        _Error = null;
        project.Languages.Remove(code);

        // Remove all translations for this language from every key
        foreach (LocalizationKeyDto key in project.Keys)
            key.Translations.RemoveAll(t => t.LanguageId == code);

        _ProjectState.MarkDirty();
    }

    private void SetMain(string code)
    {
        ProjectDto project = _ProjectState.CurrentProject!;
        if (!project.Languages.Contains(code)) return;

        project.MainLanguageId = code;
        _Error                 = null;
        _ProjectState.MarkDirty();
    }

}
